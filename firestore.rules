rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Helper: check if the requesting user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // Users can read/write their own doc. Admins can read all and update roles.
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
    }

    // ── Drills ───────────────────────────────────────────────────────────────
    // Any authenticated user can read published drills. Only admins can write.
    match /drills/{drillId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Practice Plans ────────────────────────────────────────────────────────
    // Users own their own plans.
    match /practicePlans/{planId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // ── Practice Sessions ─────────────────────────────────────────────────────
    // Users own their own sessions.
    match /practiceSessions/{sessionId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // ── Goals ─────────────────────────────────────────────────────────────────
    match /goals/{goalId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // ── AI Coaching Reports ───────────────────────────────────────────────────
    match /aiCoaching/{coachingId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // ── Chords ────────────────────────────────────────────────────────────────
    // Any authenticated user can read. Only admins can write.
    match /chords/{chordId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Lessons ───────────────────────────────────────────────────────────────
    // Authenticated users can read published lessons. Admins can read/write all.
    match /lessons/{lessonId} {
      allow read:  if request.auth != null
                   && (resource.data.published == true || isAdmin());
      allow write: if isAdmin();
    }
  }
}
